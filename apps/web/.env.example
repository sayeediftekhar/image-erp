# Copy this file to .env.local and fill in the values from your Supabase project dashboard.
# Project Settings → API → Project URL and anon/public key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-only (no NEXT_PUBLIC_ prefix so Next.js never ships it to the browser).
# Used only by apps/web/src/app/api/admin/create-user/route.ts (server-side Route Handler).
# Source: Supabase dashboard → Project Settings → API → service_role key.
# NEVER commit the actual value; this file is safe (values are blank).
SUPABASE_SERVICE_ROLE_KEY=
